{
  "name": "inetzero-mobile",
  "version": "1.0.0",
  "description": "iNetZero Mobile App - ESG Carbon Management",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "pod-install": "cd ios && pod install && cd ..",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace iNetZero.xcworkspace -scheme iNetZero -configuration Release"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.6",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "react-native-screens": "^3.31.1",
    "react-native-safe-area-context": "^4.10.1",
    "@reduxjs/toolkit": "^2.2.1",
    "react-redux": "^9.1.0",
    "redux-persist": "^6.0.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "react-native-sqlite-storage": "^6.0.1",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-firebase/app": "^19.1.2",
    "@react-native-firebase/messaging": "^19.1.2",
    "react-native-push-notification": "^8.1.1",
    "react-native-vector-icons": "^10.0.3",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-charts-wrapper": "^0.6.0",
    "axios": "^1.6.7",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-gesture-handler": "^2.16.0",
    "react-native-reanimated": "^3.8.1",
    "date-fns": "^3.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/runtime": "^7.24.0",
    "@react-native/babel-preset": "^0.73.21",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.5",
    "@react-native/typescript-config": "^0.73.1",
    "@types/react": "^18.2.66",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.7",
    "typescript": "^5.4.2",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.5",
    "detox": "^20.18.5"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation)/)"
    ]
  }
}
