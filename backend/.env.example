# =============================================================================
# NetZero Platform - Environment Configuration Template
# =============================================================================
# SECURITY WARNING: This file is a TEMPLATE ONLY
# DO NOT commit actual secrets or passwords to git
# Copy this file to .env and update with your actual values
# Always keep .env in .gitignore
# =============================================================================

# Database Configuration
# Format: postgresql://username:password@host:port/database_name
# Development: postgresql://user:password@localhost:5432/netzero
# Railway.sh: postgresql://postgres:password@host.railway.internal:5432/railway?sslmode=require
# Vercel: Set via Vercel project settings → Environment Variables
DATABASE_URL=postgresql://user:password@localhost:5432/netzero

# Connection Pool Configuration
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=40
DATABASE_POOL_PRE_PING=true

# Individual connection components (optional, mainly for reference)
DB_USER=netzero
DB_PASSWORD=your_secure_password_here
DB_NAME=netzero
DB_HOST=localhost
DB_PORT=5432

# Security & JWT
# Generate SECRET_KEY using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_minimum_32_characters_required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_TITLE=NetZero API
API_VERSION=1.0.0
DEBUG=False
ENV=development

# Logging
LOG_LEVEL=info

# API Keys
API_KEY=your_api_key_here_change_in_production

# Keycloak (Optional - uncomment if using Keycloak authentication)
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=netzero
# KEYCLOAK_CLIENT_ID=netzero-api
# KEYCLOAK_CLIENT_SECRET=your_client_secret_here

# CORS Configuration (Optional)
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Vercel Postgres (Optional - for production)
# VERCEL_POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database

# Python Configuration
PYTHONUNBUFFERED=1

# =============================================================================
# SETUP INSTRUCTIONS:
# =============================================================================
# 1. Copy this file to .env:
#    cp backend/.env.example backend/.env
#
# 2. Update all placeholder values with your actual credentials
#
# 3. Verify .env is in .gitignore (it should be)
#
# 4. For Docker Compose, create a .env file in the root directory:
#    cp backend/.env.example .env
#    Update with your Docker-specific values
#
# 5. Never commit .env to git
#
# 6. For CI/CD pipelines (GitHub Actions, Vercel), use GitHub Secrets
#    See docs/SETUP_ENVIRONMENT.md for detailed instructions
# =============================================================================
