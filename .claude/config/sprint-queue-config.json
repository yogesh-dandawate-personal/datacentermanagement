{
  "sprint_queue_system": {
    "version": "1.0",
    "enabled": true,
    "description": "Autonomous Sprint Queue Execution System with Ralph Loop and Agent Teams"
  },
  "execution_settings": {
    "max_concurrent_sprints": 2,
    "ralph_loop_enabled": true,
    "auto_recovery_enabled": true,
    "phase_timeout_minutes": 480,
    "checkpoint_interval_minutes": 5,
    "status_report_interval_minutes": 30
  },
  "ralph_phases": {
    "R0_CONTEXT": {
      "name": "Context Gathering",
      "description": "Understand requirements and objectives",
      "est_duration_minutes": 30,
      "tasks": ["Define scope", "Gather requirements", "Identify constraints"]
    },
    "R1_ANALYSIS": {
      "name": "Analysis",
      "description": "Analyze scope and complexity",
      "est_duration_minutes": 45,
      "tasks": ["Analyze requirements", "Assess complexity", "Identify risks"]
    },
    "R2_PLANNING": {
      "name": "Planning",
      "description": "Create implementation plan",
      "est_duration_minutes": 60,
      "tasks": ["Create implementation plan", "Define milestones", "Allocate resources"]
    },
    "R3_SETUP": {
      "name": "Setup",
      "description": "Setup project infrastructure",
      "est_duration_minutes": 45,
      "tasks": ["Setup repositories", "Configure CI/CD", "Setup databases"]
    },
    "R4_DEVELOPMENT": {
      "name": "Development",
      "description": "Core feature development",
      "est_duration_minutes": 480,
      "tasks": ["Implement features", "Write code", "Create tests"]
    },
    "R5_INTEGRATION": {
      "name": "Integration",
      "description": "Component integration",
      "est_duration_minutes": 240,
      "tasks": ["Integrate components", "Test integrations", "Fix issues"]
    },
    "R6_TESTING": {
      "name": "Testing",
      "description": "Comprehensive testing",
      "est_duration_minutes": 180,
      "tasks": ["Run tests", "Test coverage", "Performance testing"]
    },
    "R7_DEPLOYMENT": {
      "name": "Deployment",
      "description": "Deployment and cleanup",
      "est_duration_minutes": 120,
      "tasks": ["Deploy to production", "Verify deployment", "Cleanup"]
    }
  },
